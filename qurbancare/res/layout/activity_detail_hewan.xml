<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F1E8">

    <ImageView
        android:id="@+id/imgFullBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.12" />

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/ic_back_white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideline_header" />

    <TextView
        android:id="@+id/txtTitlePage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:text="Detail Hewan Qurban"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <ImageView
        android:id="@+id/imgHewanDetail"
        android:layout_width="match_parent"
        android:layout_height="248dp"
        android:layout_marginTop="10dp"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toBottomOf="@id/txtTitlePage"
        tools:src="@drawable/sapii" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/btnLihatDetailFigma"
        app:layout_constraintTop_toBottomOf="@id/imgHewanDetail">

        <LinearLayout
            android:id="@+id/containerInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_detail_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvNamaDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sapi Pak Tani"
                android:textColor="#000000"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBeratDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="300 - 350kg"
                android:textColor="#666666"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tvUmurDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Umur: 2 Tahun"
                    android:textColor="#5D3737"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:text="|"
                    android:textColor="#CCCCCC" />
                <TextView
                    android:id="@+id/tvJenisKelaminDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kelamin: Jantan"
                    android:textColor="#5D3737"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvHargaDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="Rp 35.000.000,00"
                android:textColor="#5D3737"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvInfoHarga"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="*Harga total hewan"
                android:textColor="#FF9800"
                android:textSize="12sp"
                android:textStyle="italic" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Deskripsi:"
                android:textColor="#000000"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDeskripsiDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Deskripsi akan muncul di sini..."
                android:textColor="#444444"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/layoutSlotGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:orientation="vertical"
                android:background="#105D3737"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tvLabelSlot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status Slot Patungan:"
                    android:textColor="#000000"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progressPatungan"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="10dp"
                    android:max="7"
                    android:progress="3"
                    android:progressDrawable="@drawable/custom_progress_bar" />

                <TextView
                    android:id="@+id/tvStatusSlot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Rp 5.000.000,00 / 1 👤"
                    android:textColor="#666666"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="120dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ImageButton
        android:id="@+id/btnLihatDetailFigma"
        android:layout_width="273dp"
        android:layout_height="80dp"
        android:background="@android:color/transparent"
        android:scaleType="fitCenter"
        android:src="@drawable/btn"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>