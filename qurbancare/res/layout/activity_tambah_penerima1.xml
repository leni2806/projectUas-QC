<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tambah Penerima Baru"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Lengkap"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/etNamaPenerima"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/btn_kambing_inactive"
            android:hint="Contoh: Leni Septiani"
            android:paddingLeft="15dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alamat"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/etAlamat"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/btn_kambing_inactive"
            android:hint="Masukkan alamat lengkap..."
            android:gravity="top"
            android:padding="15dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kategori"
            android:layout_marginBottom="8dp"/>
        <Spinner
            android:id="@+id/spKategori"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/btn_kambing_inactive"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Berat Paket (kg)"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/etBeratPaket"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/btn_kambing_inactive"
            android:hint="Contoh: 1"
            android:inputType="number"
            android:paddingLeft="15dp"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnSimpan"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Simpan Data"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>