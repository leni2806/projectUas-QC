<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_white_rounded">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tambah Penerima Baru"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1E7A4C"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"/>

    <EditText
        android:id="@+id/etNamaBaru"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Nama Lengkap"
        android:background="@drawable/search_bg"
        android:paddingHorizontal="15dp"
        android:layout_marginBottom="12dp"
        android:textSize="14sp"/>

    <EditText
        android:id="@+id/etNikBaru"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Nomor Induk Kependudukan (NIK)"
        android:inputType="number"
        android:background="@drawable/search_bg"
        android:paddingHorizontal="15dp"
        android:layout_marginBottom="12dp"
        android:textSize="14sp"/>

    <EditText
        android:id="@+id/etAlamatBaru"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Alamat (RT/RW/No Rumah)"
        android:background="@drawable/search_bg"
        android:paddingHorizontal="15dp"
        android:layout_marginBottom="12dp"
        android:textSize="14sp"/>

    <EditText
        android:id="@+id/etTelpBaru"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Nomor Telepon (WhatsApp)"
        android:inputType="phone"
        android:background="@drawable/search_bg"
        android:paddingHorizontal="15dp"
        android:layout_marginBottom="12dp"
        android:textSize="14sp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pilih Kategori &amp; Jenis Kelamin"
        android:textSize="11sp"
        android:textColor="#666666"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="5dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <Spinner
            android:id="@+id/spKategori"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:entries="@array/kategori_array"
            android:background="@drawable/search_bg"
            android:padding="5dp"/>

        <View
            android:layout_width="10dp"
            android:layout_height="match_parent"/>

        <Spinner
            android:id="@+id/spGender"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:entries="@array/gender_array"
            android:background="@drawable/search_bg"
            android:padding="5dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnSimpanPenerima"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Simpan Data Penerima"
        android:textAllCaps="false"
        android:backgroundTint="#1E7A4C"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="15dp"
        android:elevation="4dp"/>

</LinearLayout>