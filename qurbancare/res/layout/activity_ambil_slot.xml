<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F1E8">

    <ImageView
        android:id="@+id/imgFullBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.12" />

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:layout_marginStart="16dp"
        android:src="@drawable/ic_back_white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideline_top" />

    <TextView
        android:id="@+id/txtTitlePage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:text="Pilih Slot Qurban"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <ImageView
        android:id="@+id/imgHewanAmbilSlot"
        android:layout_width="match_parent"
        android:layout_height="230dp"
        android:layout_marginTop="20dp"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toBottomOf="@id/txtTitlePage"
        tools:src="@drawable/sapii" />

    <LinearLayout
        android:id="@+id/containerAmbilSlot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_detail_card"
        android:elevation="4dp"
        android:orientation="vertical"
        android:padding="25dp"
        app:layout_constraintTop_toBottomOf="@id/imgHewanAmbilSlot">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pilih Slot Kamu"
            android:textColor="#000000"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progressAmbilSlot"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginTop="12dp"
            android:max="7"
            android:progressDrawable="@drawable/custom_progress_bar" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Pilih slot yang masih tersedia"
            android:textColor="#666666"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/slot1"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="6dp"
                android:background="@drawable/bg_slot_empty"
                android:gravity="center"
                android:text="1"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/slot2"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="6dp"
                android:background="@drawable/bg_slot_empty"
                android:gravity="center"
                android:text="2"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/slot3"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="6dp"
                android:background="@drawable/bg_slot_empty"
                android:gravity="center"
                android:text="3"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/slot4"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="6dp"
                android:background="@drawable/bg_slot_empty"
                android:gravity="center"
                android:text="4"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/slot5"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="6dp"
                android:background="@drawable/bg_slot_empty"
                android:gravity="center"
                android:text="5"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/slot6"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="6dp"
                android:background="@drawable/bg_slot_empty"
                android:gravity="center"
                android:text="6"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/slot7"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="6dp"
                android:background="@drawable/bg_slot_empty"
                android:gravity="center"
                android:text="7"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnLanjutPembayaran"
            android:layout_width="273dp"
            android:layout_height="65dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="30dp"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:src="@drawable/btnn" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>