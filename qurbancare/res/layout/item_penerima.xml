<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="15dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FDF8ED">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <ImageView
            android:id="@+id/imgAvPenerima"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:src="@drawable/avatar_boy"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/layoutInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/layoutKanan"
            app:layout_constraintStart_toEndOf="@id/imgAvPenerima"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvNamaPenerima"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Penerima"
                android:textColor="#333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvKatPenerima"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kategori"
                android:textColor="#666"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvDetPenerima"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Info Alamat | No HP"
                android:textColor="#888"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutKanan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvStatAmbil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_kuning"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Belum diambil"
                android:textColor="#FFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnEdPenerima"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="55dp"
                    android:layout_height="35dp"
                    android:backgroundTint="#8BC34A"
                    android:padding="0dp"
                    android:text="Edit"
                    android:textAllCaps="false"
                    android:textColor="#FFF"
                    android:textSize="10sp" />

                <Button
                    android:id="@+id/btnHapPenerima"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="55dp"
                    android:layout_height="35dp"
                    android:layout_marginStart="4dp"
                    android:backgroundTint="#EF5350"
                    android:padding="0dp"
                    android:text="Hapus"
                    android:textAllCaps="false"
                    android:textColor="#FFF"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>