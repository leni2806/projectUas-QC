<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imgFullBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/frame" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="130dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back_white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#000000" />

    <TextView
        android:id="@+id/tvJudul"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:text="Distribusi Daging"
        android:textColor="#000000"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <GridLayout
        android:id="@+id/layoutDashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="20dp"
        android:columnCount="2"
        app:layout_constraintTop_toBottomOf="@id/tvJudul">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#F5EEDA">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/box" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total"
                        android:textSize="9sp"/>
                    <TextView
                        android:id="@+id/tvTotalPaket"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 Paket"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#000"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#F5EEDA">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/daging" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Daging"
                        android:textSize="9sp"/>
                    <TextView
                        android:id="@+id/tvBerat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 kg"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#000"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#F5EEDA">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/jam" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Belum"
                        android:textSize="9sp"/>
                    <TextView
                        android:id="@+id/tvBelumDiambil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 Pkt"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#000"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#DDE5D7">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/sukses" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selesai"
                        android:textSize="9sp"/>
                    <TextView
                        android:id="@+id/tvSudahDiambil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 Pkt"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#000"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </GridLayout>

    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/layoutDashboard">

        <Button
            android:id="@+id/btnTambah"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="+ Tambah"
            android:textSize="9sp"
            android:layout_marginEnd="3dp"
            android:backgroundTint="#2D5A27"
            android:textAllCaps="false"
            android:padding="0dp"/>

        <Button
            android:id="@+id/btnAksi"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1.1"
            android:text="Menu Aksi"
            android:textSize="9sp"
            android:layout_marginEnd="3dp"
            android:backgroundTint="#F2C94C"
            android:textColor="#000000"
            android:textAllCaps="false"
            android:padding="0dp"/>

        <Button
            android:id="@+id/btnRuteMaps"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1.2"
            android:text="🚗 Rute"
            android:textSize="9sp"
            android:layout_marginEnd="3dp"
            android:backgroundTint="#6E95C0"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:padding="0dp"/>

        <Button
            android:id="@+id/btnLaporan"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Laporan"
            android:textSize="9sp"
            android:backgroundTint="#FFFFFF"
            android:textColor="#2D5A27"
            android:textAllCaps="false"
            android:padding="0dp"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardKalkulator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="15dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/layoutButtons">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#FFFFFF">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kalkulator Timbangan Sapi"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#2D5A27"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/etBeratSapiInput"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:hint="Input Berat Sapi (kg)"
                    android:inputType="numberDecimal"
                    android:textSize="13sp"
                    android:background="@drawable/bg_search_rounded"
                    android:paddingHorizontal="15dp"/>

                <androidx.cardview.widget.CardView
                    android:id="@+id/btnHitungDistribusi"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="10dp"
                    app:cardCornerRadius="24dp"
                    app:cardBackgroundColor="#2D5A27"
                    app:cardElevation="2dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"
                        android:src="@android:drawable/ic_menu_send"
                        app:tint="#FFFFFF" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:layout_marginEnd="4dp"
                    android:background="#F0F4EF"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Shohibul"
                        android:textSize="10sp"
                        android:textColor="#666"/>
                    <TextView
                        android:id="@+id/tvHasilShohibul"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="- kg"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#2D5A27"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:layout_marginStart="4dp"
                    android:background="#FEF9E7"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Paket Warga"
                        android:textSize="10sp"
                        android:textColor="#666"/>
                    <TextView
                        android:id="@+id/tvHasilKantong"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="- Ktg"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#D4A373"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDistribusi"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardKalkulator" />

</androidx.constraintlayout.widget.ConstraintLayout>