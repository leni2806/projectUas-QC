<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="15dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/imgHewanPekurban"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:src="@drawable/logo" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNamaPekurban"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Pekurban"
                android:textSize="16sp"
                android:fontFamily="@font/poppinsbold"
                android:textColor="#2D3436"/>

            <TextView
                android:id="@+id/tvDetailHewan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sapi Limosin - 350kg"
                android:textSize="13sp"
                android:fontFamily="@font/poppinsregular"
                android:textColor="#636E72"/>

            <TextView
                android:id="@+id/tvStatusKurban"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Terverifikasi"
                android:textSize="11sp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:background="@drawable/bg_status_hijau"
                android:textColor="#FFFFFF"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>