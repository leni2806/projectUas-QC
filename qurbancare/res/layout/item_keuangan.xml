<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <View
            android:id="@+id/viewIndikator"
            android:layout_width="5dp"
            android:layout_height="50dp"
            android:background="#2D5A27" />

        <ImageView
            android:id="@+id/ivBuktiNota"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="10dp"
            android:scaleType="centerCrop"
            android:background="#F0F0F0"
            android:visibility="gone"
            android:src="@android:drawable/ic_menu_gallery" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNamaTransaksi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pembayaran - Agus"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333"/>

            <TextView
                android:id="@+id/tvTanggal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="11 Apr 2026 | 10:00"
                android:textSize="11sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvNominal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 3.500.000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#2D5A27"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lunas"
                android:textSize="10sp"
                android:textStyle="italic"
                android:textColor="#2D5A27"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>