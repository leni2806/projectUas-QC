<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAF8">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/headerRekening"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        app:cardCornerRadius="0dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#2E7D32"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btnBackRekening"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kelola Rekening Bendahara"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/headerRekening">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Informasi Rekening Pembayaran"
                android:textColor="#2E7D32"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etNamaBank"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Nama Bank (Contoh: BSI, BCA)"
                android:background="@drawable/edittext_grey_bg"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:inputType="textCapCharacters"/>

            <EditText
                android:id="@+id/etNoRekening"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Nomor Rekening"
                android:background="@drawable/edittext_grey_bg"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:inputType="number"/>

            <EditText
                android:id="@+id/etAtasNama"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Atas Nama (A.N)"
                android:background="@drawable/edittext_grey_bg"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="24dp"
                android:inputType="textPersonName"/>

            <Button
                android:id="@+id/btnSimpanRekening"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Simpan Rekening Baru"
                android:backgroundTint="#2E7D32"
                android:textColor="#FFFFFF"
                app:cornerRadius="25dp"
                android:textStyle="bold"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>